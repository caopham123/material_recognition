# ==============================================================================
# HƯỚNG DẪN SETUP MÔI TRƯỜNG (Dành cho Developer / Kỹ sư triển khai)
# 
# BƯỚC 1: Copy các biến ở mục [SERVER] vào file server_core/.env và điền giá trị thật.
# BƯỚC 2: Copy các biến ở mục [CLIENT] vào file client_edge/.env và điền giá trị thật.
# TUYỆT ĐỐI KHÔNG COMMIT CÁC FILE .env THẬT LÊN GIT!
# ==============================================================================

# ------------------------------------------------------------------------------
#[SERVER] - CẤU HÌNH CHO SERVER CORE & DATABASE
# ------------------------------------------------------------------------------
POSTGRES_USER=change_this_user
POSTGRES_PASSWORD=change_this_password
POSTGRES_DB=change_this_db_name
DATABASE_URL=postgresql+asyncpg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@postgres_db:5432/${POSTGRES_DB}

ENVIRONMENT=development
PORT=8000
CONFIDENCE_THRESHOLD=0.85
SAVE_HARD_CASES=True

# ------------------------------------------------------------------------------
# [CLIENT] - CẤU HÌNH CHO EDGE PC (TRẠM CAMERA)
# ------------------------------------------------------------------------------
STATION_ID=STATION_TEST_01
CAMERA_ID=CAM_TEST_01
RTSP_URL=rtsp://username:password@ip_address:554/stream
SERVER_URL=http://server_core:8000/api/v1/predict
API_KEY=your_secret_api_key

TARGET_FPS=5
MAX_MISSED_FRAMES=15